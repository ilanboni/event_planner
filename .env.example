# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here   # any long random string
WEBHOOK_BASE_URL=https://your-railway-app.up.railway.app

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── Database ──────────────────────────────────────────────────────────────────
# Local development:
DATABASE_URL=sqlite+aiosqlite:///./event_planner.db
# Railway (after adding a volume mounted at /data):
# DATABASE_URL=sqlite+aiosqlite:////data/event_planner.db

# ── Storage ───────────────────────────────────────────────────────────────────
# Local development:
FILES_STORAGE_PATH=./data/files
# Railway (same volume as database):
# FILES_STORAGE_PATH=/data/files

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
